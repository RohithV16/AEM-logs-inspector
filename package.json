{
  "name": "aem-log-analyzer",
  "version": "1.0.0",
  "description": "AEM Log Analyzer - CLI and Dashboard for analyzing Adobe Experience Manager logs",
  "main": "src/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/RohithV16/AEM-logs-inspector"
  },
  "keywords": [
    "aem",
    "adobe",
    "logs",
    "analyzer",
    "dashboard"
  ],
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "node src/index.js",
    "dashboard": "node src/server.js",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:api": "node scripts/test-api.js",
    "test:api:start": "npm run dashboard & PID=$!; sleep 3; node scripts/test-api.js; kill $PID",
    "lint": "eslint src/**/*.js"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.1",
    "chart.js": "^4.5.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "jspdf": "^4.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ws": "^8.16.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "js-yaml": "^4.1.1",
    "playwright": "^1.59.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  }
}
